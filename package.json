{
  "name": "gambling-bot-discord",
  "version": "1.0.0",
  "main": "src/app.ts",
  "type": "module",
  "scripts": {
    "dev": "commandkit dev",
    "build": "commandkit build",
    "start": "commandkit start",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,tsx}\"",
    "lint:check": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix --max-warnings 0",
    "type:check": "tsc --noEmit",
    "test:check": "vitest run",
    "test:coverage:check": "vitest run --coverage",
    "test:unit:check": "vitest run tests/unit",
    "test:integration:check": "vitest run tests/integration",
    "test:watch": "vitest",
    "check": "pnpm format:check && pnpm lint:check && pnpm type:check && pnpm test:check",
    "clean": "rm -rf dist .commandkit node_modules coverage",
    "docs:commands": "tsx src/scripts/generate-commands-structure.ts",
    "audit:economy": "tsx src/scripts/audit-economy-summary.ts",
    "audit:balance": "tsx src/scripts/audit-balances.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "packageManager": "pnpm@10.28.0",
  "pnpm": {
    "ignoredBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "commandkit": "^1.2.1",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "gambling-bot-shared": "^0.1.40",
    "lodash": "^4.18.1",
    "luxon": "^3.7.2",
    "mongoose": "^9.6.2",
    "pino": "^10.3.1",
    "tsx": "^4.22.3"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/lodash": "^4.17.24",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "mongodb-memory-server": "^11.1.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "ts-morph": "^28.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
