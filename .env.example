# LOG_LEVEL — minimum log level (Pino). Leave empty: debug in dev, info in production.
#
# Levels this bot actually uses:
#   info  — boot, ready, worker, event (logger.boot / ready / worker / event)
#   error — failures (logger.error)
#
# Set LOG_LEVEL=error to show only errors (hides boot, workers, audit events).
LOG_LEVEL=
